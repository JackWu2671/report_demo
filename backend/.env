# LLM 配置
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL_NAME=qwen3-27b
LLM_TEMPERATURE=0.1
LLM_TOP_P=1.0
LLM_TIMEOUT=120
LLM_API_KEY=
# qwen3 | r1 | none  (qwen3/r1 会剥除 <think>…</think> 推理内容)
LLM_THINK_TAG_MODE=qwen3

# Embedding 配置
EMBEDDING_BASE_URL=http://localhost:8001/v1
EMBEDDING_DIM=1024

# FAISS 检索阈值（余弦相似度，范围 0~1，越低召回越多）
FAISS_SCORE_THRESHOLD=0.3
